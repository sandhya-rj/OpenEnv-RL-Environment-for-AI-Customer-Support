# .dockerignore — prevent unnecessary files from being sent to the Docker build context

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# Test cache
.pytest_cache/
.coverage
htmlcov/
.tox/

# Version control
.git/
.gitignore
.gitattributes

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local env
.env
.env.*
*.local

# Docs and markdown (not needed in container)
README.md
*.md

# This file itself
.dockerignore
